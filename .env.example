# GEMINI_API_KEY: Required if utilizing Google Gemini models.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# OPENAI_API_KEY: Alternative API key to use OpenAI instead of Google Gemini (e.g. on Vercel)
OPENAI_API_KEY=

# OPENAI_API_MODEL: Optional OpenAI model ID. Defaults to "gpt-4o-mini"
OPENAI_API_MODEL=gpt-4o-mini

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
